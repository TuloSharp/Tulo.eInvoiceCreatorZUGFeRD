<UserControl x:Class="tulo.eInvoiceCreatorZUGFeRD.Controls.SaveRequestMessageControlNew"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Visibility="{Binding IsSaveRequestMessageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="8" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="9" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <StackPanel Background="{StaticResource WarningBrushColor}">
                <DockPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="9" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="10" />
                        </Grid.ColumnDefinitions>
                        <Viewbox Grid.Column="1"
                                 Width="30"
                                 Height="30"
                                 Margin="0,2,0,2">
                            <Path Data="{StaticResource WarningWideIconSVG}"
                                  Fill="Black"
                                  HorizontalAlignment="Left"
                                  Stretch="Fill"
                                  Height="40"
                                  Width="40" />
                        </Viewbox>
                        <Label Name="SaveRequestMessage"
                               Grid.Column="3"
                               Padding="0,8,0,0"
                               Foreground="Black"
                               FontSize="16"
                               Margin="0,1,0,0"
                               Content="{Binding LabelSaveRequestMessage}"
                               HorizontalAlignment="Left" />

                        <Button Name="saveButton"
                                Grid.Column="5"
                                Margin="0,2,0,2"
                                Style="{StaticResource ToolbarPrimaryButton}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource DoneIconSVG}"
                                      Fill="White"
                                      Width="14"
                                      Height="14"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />
                                <AccessText Text="{Binding ContentButtonSaveSaveRequestMessage}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Name="noButton"
                                Grid.Column="7"
                                Margin="0,2,0,2"
                                Style="{StaticResource ToolbarDangerButton}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource CloseIconSVG}"
                                      Fill="#DC3545"
                                      Width="14"
                                      Height="14"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />
                                <AccessText Text="{Binding ContentButtonNoSaveRequestMessage}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Name="requestedReturnButton"
                                Grid.Column="9"
                                Margin="0,2,0,2"
                                Style="{StaticResource ToolbarSecondaryButton}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource ArrowBackIconSVG}"
                                      Fill="#3B82F6"
                                      Width="14"
                                      Height="14"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />
                                <AccessText Text="{Binding ContentButtonReturnSaveRequestMessage}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                    </Grid>
                </DockPanel>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Background="Transparent" />
    </Grid>
</UserControl>
