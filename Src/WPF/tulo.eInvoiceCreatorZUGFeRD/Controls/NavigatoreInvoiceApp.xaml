<UserControl x:Class="tulo.eInvoiceCreatorZUGFeRD.Controls.NavigatoreInvoiceApp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.Controls"
             xmlns:navType="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.Utilities"
             xmlns:viewmodels="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.ViewModels"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             xmlns:invoiceviewmodels="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.ViewModels.Invoices"
             xmlns:sellerviewmodels="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.ViewModels.Sellers"
             xmlns:aboutviewmodels="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.ViewModels.About"
             d:DesignHeight="1250"
             d:DesignWidth="100"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/tulo.ResourcesWpfLib;component/Resources/CommonResources.xaml" />
                <ResourceDictionary Source="pack://application:,,,/tulo.ResourcesWpfLib;component/Resources/SVGResources.xaml" />
                <ResourceDictionary Source="pack://application:,,,/tulo.ResourcesWpfLib;component/Resources/NavigationBarResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:EqualValueToParameterConverter x:Key="EqualValueToParameterConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Background="{StaticResource BackgroundNavigatorBrushColor}"
                  RenderOptions.EdgeMode="Aliased">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  ── Invoice ──  -->
                    <RadioButton Grid.Row="1"
                                 Style="{StaticResource ModernNavButton}"
                                 ToolTip="{Binding ToolTipInvoiceViewIcon}"
                                 Command="{Binding UpdateCurrentViewModelCommand}"
                                 CommandParameter="{x:Static navType:NavTypes.InvoiceView}"
                                 IsChecked="{Binding CurrentViewModel, Mode=OneWay, Converter={StaticResource EqualValueToParameterConverter}, ConverterParameter={x:Type invoiceviewmodels:InvoiceViewModel}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🧾"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="{Binding NavLabelInvoice}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <!--  ── Seller ──  -->
                    <RadioButton Grid.Row="2"
                                 Style="{StaticResource ModernNavButton}"
                                 ToolTip="{Binding ToolTipBuyerViewIcon}"
                                 Command="{Binding UpdateCurrentViewModelCommand}"
                                 CommandParameter="{x:Static navType:NavTypes.SellerView}"
                                 IsChecked="{Binding CurrentViewModel, Mode=OneWay, Converter={StaticResource EqualValueToParameterConverter}, ConverterParameter={x:Type sellerviewmodels:SellerViewModel}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🏢"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="{Binding NavLabelSeller}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <!--  ── About (down) ──  -->
                    <RadioButton Grid.Row="10"
                                 Style="{StaticResource ModernNavButton}"
                                 ToolTip="{Binding ToolTipAboutViewIcon}"
                                 Command="{Binding UpdateCurrentViewModelCommand}"
                                 CommandParameter="{x:Static navType:NavTypes.AboutView}"
                                 IsChecked="{Binding CurrentViewModel, Mode=OneWay, Converter={StaticResource EqualValueToParameterConverter}, ConverterParameter={x:Type aboutviewmodels:AboutViewModel}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="ℹ️"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="{Binding NavLabelAbout}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                </Grid>
            </Grid>
        </Grid>
    </Border>

</UserControl>
