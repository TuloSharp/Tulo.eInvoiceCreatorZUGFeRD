<UserControl x:Class="tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.AddInvoicePositionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoiceCreatorZUGFeRD.Views.Invoices"
             xmlns:flag="clr-namespace:System;assembly=mscorlib"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:commoncontrols="clr-namespace:tulo.ResourcesWpfLib.Controls.Common;assembly=tulo.ResourcesWpfLib"
             xmlns:extended="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             Focusable="True"
             FocusManager.IsFocusScope="True"
             KeyboardNavigation.TabNavigation="Cycle"
             extended:SetFocusOnModalShow.Enabled="True"
             Background="White"
             Style="{StaticResource RoundedUserControlStyle}"
             ToolTipService.InitialShowDelay="500"
             mc:Ignorable="d"
             Width="670"
             Height="Auto"
             d:DesignHeight="330"
             d:DesignWidth="670">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:DebuggerConverter x:Key="DebuggerConverter" />
            <converters:ButtonStateDiagnosticConverter x:Key="ButtonStateDiagnosticConverter" />
            <flag:Boolean x:Key="TrueFlag">True</flag:Boolean>
            <flag:Boolean x:Key="FalseFlag">False</flag:Boolean>

            <!--  Primary toolbar button (blue, solid) – e.g., Save  -->
            <Style x:Key="ToolbarPrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="#3B82F6" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="16,8" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2563EB" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1D4ED8" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#CBD5E1" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--  Secondary toolbar button (blue, outline) – e.g., Load  -->
            <Style x:Key="ToolbarSecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="White" />
                <Setter Property="Foreground" Value="#3B82F6" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="16,8" />
                <Setter Property="BorderThickness" Value="1.5" />
                <Setter Property="BorderBrush" Value="#3B82F6" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#EFF6FF" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#DBEAFE" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#CBD5E1" />
                                    <Setter Property="Foreground" Value="#CBD5E1" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="PreviewKeyDown">
            <behaviors:InvokeCommandAction Command="{Binding IsAltShortcutKeyPressedCommand}" PassEventArgsToCommand="True" />
        </behaviors:EventTrigger>
        <behaviors:EventTrigger EventName="PreviewKeyUp">
            <behaviors:InvokeCommandAction Command="{Binding IsAltShortcutKeyReleasedCommand}" PassEventArgsToCommand="True" />
        </behaviors:EventTrigger>
        <behaviors:EventTrigger EventName="Deactivated">
            <behaviors:InvokeCommandAction Command="{Binding IsAltShortcutKeyReleasedCommand}" />
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>

    <UserControl.InputBindings>
        <KeyBinding Modifiers="Alt"
                    Key="F4"
                    Command="{Binding CloseAddInvoicePositionDetailsCommand}" />
        <KeyBinding Key="Esc" Command="{Binding CloseAddInvoicePositionDetailsCommand}" />
    </UserControl.InputBindings>

    <Grid ToolTipService.ShowOnDisabled="True">
        <!--  this definition replace the SizeToContent property, because in user control doesn't exist this property  -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="25" />
                <RowDefinition Height="40" />
                <RowDefinition Height="0" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="6" />
            </Grid.RowDefinitions>

            <Border CornerRadius="2"
                    BorderBrush="{StaticResource MainBrushColor}"
                    BorderThickness="0,2,0,0"
                    ClipToBounds="True">
                <Grid Grid.Row="0"
                      Background="{StaticResource MainBrushColor}"
                      Focusable="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="2" />
                    </Grid.ColumnDefinitions>

                    <Image Margin="1,0,0,0"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Width="20"
                           Height="20"
                           Source="/Assets/TuloTeam.ico" />

                    <TextBlock Grid.Column="1"
                               MaxWidth="2000"
                               Padding="4,3,0,0"
                               Foreground="White"
                               Text="{Binding LabelCreateInvoicePosition}" />

                    <Button x:Name="btnClose"
                            Grid.Column="2"
                            Focusable="False"
                            Style="{StaticResource CloseWinButton}"
                            IsEnabled="{Binding IsSaveRequestMessageVisible, Converter={StaticResource InverseBoolConverter}}"
                            Width="22"
                            Height="22"
                            Cursor="Hand"
                            Background="{StaticResource MainBrushColor}"
                            BorderBrush="Transparent"
                            Foreground="Transparent"
                            Command="{Binding CloseAddInvoicePositionDetailsCommand}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <Grid Width="14" Height="14">
                            <Path Style="{StaticResource WinCloseButtonPathStyle}"
                                  Data="{StaticResource CloseIconSVG}"
                                  Fill="{StaticResource ButtonBrushIconColor}"
                                  Stretch="Fill" />
                        </Grid>
                        <behaviors:Interaction.Triggers>
                            <behaviors:KeyTrigger Key="Esc">
                                <behaviors:InvokeCommandAction Command="{Binding CloseAddInvoicePositionDetailsCommand}" />
                            </behaviors:KeyTrigger>
                        </behaviors:Interaction.Triggers>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource GroupBoxBrushColor}">
                <Grid Background="{StaticResource PanelBrushColor}">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="3" />
                    </Grid.ColumnDefinitions>

                    <Button Name="requestedReturnButton"
                            Grid.Column="1"
                            Margin="0,2,0,2"
                            Style="{StaticResource ToolbarSecondaryButton}"
                            KeyboardNavigation.AcceptsReturn="False"
                            IsEnabled="{Binding IsSaveRequestMessageVisible, Converter={StaticResource InverseBoolConverter}}"
                            ToolTip="{Binding ToolTipReturn}"
                            Command="{Binding CloseAddInvoicePositionDetailsCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource ArrowBackIconSVG}"
                                  Fill="{StaticResource ButtonIconPrimaryColorBrush}"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />
                            <AccessText Text="{Binding ContentButtonReturn}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!--  ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=DataContext}"  -->
                    <!--  ToolTipService.ShowOnDisabled="True"  -->
                    <Button Name="saveButton"
                            Grid.Column="3"
                            Margin="0,2,0,2"
                            Style="{StaticResource ToolbarPrimaryButton}"
                            ToolTip="{Binding ToolTipSave}"
                            KeyboardNavigation.AcceptsReturn="False"
                            IsEnabled="{Binding IsEnableToSaveData, Converter={StaticResource DebuggerConverter}, ConverterParameter=IsEnableToSaveData}"
                            Command="{Binding AddInvoicePositionDetailsCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource DoneIconSVG}"
                                  Fill="White"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />
                            <AccessText Text="{Binding ContentButtonInsertPosition}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>


            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="14" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="6" />
                </Grid.RowDefinitions>

                <local:InvoicePositionDetailsFormView DataContext="{Binding InvoicePositionDetailsFormViewModel}" Grid.Row="1" />

                <commoncontrols:StatusMessageControl Grid.Row="2"
                                                     Margin="0,8,0,0"
                                                     Grid.Column="1"
                                                     Grid.ColumnSpan="1"
                                                     DataContext="{Binding StatusMessageViewModel}" />

                <commoncontrols:SaveRequestMessageControl DataContext="{Binding InvoicePositionDetailsFormViewModel}"
                                                          Grid.Row="3"
                                                          Margin="4,0,4,0" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
