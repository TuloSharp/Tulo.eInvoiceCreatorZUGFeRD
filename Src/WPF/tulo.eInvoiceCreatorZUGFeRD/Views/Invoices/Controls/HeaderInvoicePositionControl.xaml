<UserControl x:Class="Tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls.HeaderInvoicePositionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls"
             xmlns:placeholder="clr-namespace:tulo.PlaceholderTextBoxControl;assembly=tulo.PlaceholderTextBoxControl"
             mc:Ignorable="d"
             d:DesignHeight="44"
             MaxWidth="1000"
             d:DesignWidth="1000">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="4" />
        </Grid.ColumnDefinitions>

        <placeholder:PlaceholderTextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Grid.Column="1"
                                        ToolTip="{Binding ToolTipSearchText}"
                                        Placeholder="🔍"
                                        BorderThickness="0,0,0,0.75"
                                        Margin="0,2,4,0"
                                        Width="300"
                                        Height="24"
                                        Padding="6,2" />

        <Button Name="createButton"
                Grid.Column="3"
                Style="{StaticResource ToolbarPrimaryButton}"
                HorizontalAlignment="Center"
                ToolTip="{Binding ToolTipCreateInvoicePosition}"
                Command="{Binding OpenAddInvoicePositionViewCommand}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Path Data="{StaticResource CreateIconSVG}"
                      Fill="{StaticResource ButtonBrushIconColor}"
                      Width="14"
                      Height="14"
                      Stretch="Uniform"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0" />
                <AccessText Text="{Binding ContentButtonCreateInvoicePosition}" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

    </Grid>
</UserControl>

