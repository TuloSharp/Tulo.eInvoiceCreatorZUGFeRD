        </Border>-->

            <!-- ══════════════════════════════════════════
             RECHNUNGS-DOKUMENT (weißes "Papier")
        ══════════════════════════════════════════ -->
            <Border Background="White"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="50,40">
                <StackPanel>

                    <!-- ── KOPFZEILE: Absender links | Rechnungsinfos rechts ── -->
                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <!-- ABSENDER (Lieferant) -->
                        <StackPanel Grid.Column="0">
                            <!-- Firmenname gross -->
                            <TextBlock Text="Mustermann GmbH &amp; Co. KG"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,6"/>
                            <TextBlock Text="Industriestraße 42"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="80331 München · Deutschland"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="USt-IdNr.: DE123456789"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,4,0,0"/>
                            <TextBlock Text="Tel: +49 89 123456-0 · info@mustermann-gmbh.de"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- RECHNUNGS-INFO-BOX (rechts) -->
                        <Border Grid.Column="1"
                            Background="{StaticResource LightGrayBrush}"
                            CornerRadius="8" Padding="18,16"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="RECHNUNG"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Rechnungsnr.:"
                                           Style="{StaticResource LabelSmall}" Margin="0,0,10,6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="RE-2024-00842"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource TextDarkBrush}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Datum:"
                                           Style="{StaticResource LabelSmall}" Margin="0,0,10,6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="15.05.2024"
                                           FontSize="12" Foreground="{StaticResource TextDarkBrush}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Fällig am:"
                                           Style="{StaticResource LabelSmall}" Margin="0,0,10,6"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="29.05.2024"
                                           FontSize="12" FontWeight="Bold" Foreground="#DC3545"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Währung:"
                                           Style="{StaticResource LabelSmall}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="EUR"
                                           FontSize="12" Foreground="{StaticResource TextDarkBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── TRENNLINIE ── -->
                    <Rectangle Height="2" Fill="{StaticResource AccentBrush}"
                           RadiusX="1" RadiusY="1" Margin="0,0,0,24"/>

                    <!-- ── RECHNUNGSEMPFÄNGER ── -->
                    <StackPanel Margin="0,0,0,28">
                        <TextBlock Text="RECHNUNGSEMPFÄNGER"
                               Style="{StaticResource LabelSmall}"
                               Margin="0,0,0,6"/>
                        <Border Background="{StaticResource LightGrayBrush}"
                            CornerRadius="6" Padding="16,12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Left"
                            MinWidth="300">
                            <StackPanel>
                                <TextBlock Text="INTUS GmbH"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextDarkBrush}"/>
                                <TextBlock Text="Musterweg 7"
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="10115 Berlin · Deutschland"
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="USt-IdNr.: DE987654321"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── BETREFF / BESTELLREFERENZ ── -->
                    <StackPanel Margin="0,0,0,26">
                        <TextBlock Text="BETREFF"
                               Style="{StaticResource LabelSmall}"
                               Margin="0,0,0,4"/>
                        <TextBlock Text="Lieferung Büromaterial – Bestellnr. PO-2024-0321"
                               FontSize="13" Foreground="{StaticResource TextDarkBrush}"/>
                    </StackPanel>

                    <!-- ── POSITIONSLISTE (kein DataGrid, kein Border) ── -->
                    <TextBlock Text="RECHNUNGSPOSITIONEN"
       Style="{StaticResource LabelSmall}"
       Margin="0,0,0,10"/>

                    <StackPanel>

                        <!-- SPALTEN-HEADER -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="95"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bezeichnung"
               FontWeight="Bold" FontSize="13"
               Foreground="{StaticResource TextDarkBrush}"/>
                            <TextBlock Grid.Column="1" Text="Menge"
               FontWeight="Bold" FontSize="13"
               HorizontalAlignment="Right"
               Foreground="{StaticResource TextDarkBrush}"/>
                            <TextBlock Grid.Column="2" Text="Einheit"
               FontWeight="Bold" FontSize="13"
               HorizontalAlignment="Center"
               Foreground="{StaticResource TextDarkBrush}"/>
                            <TextBlock Grid.Column="3" Text="USt."
               FontWeight="Bold" FontSize="13"
               HorizontalAlignment="Center"
               Foreground="{StaticResource TextDarkBrush}"/>
                            <TextBlock Grid.Column="4" Text="Einzeln"
               FontWeight="Bold" FontSize="13"
               HorizontalAlignment="Right"
               Foreground="{StaticResource TextDarkBrush}"/>
                            <TextBlock Grid.Column="5" Text="Gesamt"
               FontWeight="Bold" FontSize="13"
               HorizontalAlignment="Right"
               Foreground="{StaticResource TextDarkBrush}"/>
                        </Grid>

                        <!-- GESTRICHELTE LINIE oben -->
                        <Rectangle Height="1"
       Fill="#CCCCCC"
       HorizontalAlignment="Stretch"
       Margin="0,0,0,4"/>

                        <!-- POSITIONEN -->
                        <ItemsControl x:Name="InvoiceItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="75"/>
                                            <ColumnDefinition Width="65"/>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="95"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Bezeichnung + optionale Beschreibung -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Description}"
                               FontSize="13"
                               Foreground="{StaticResource TextDarkBrush}"
                               TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding SubDescription}"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SubDescription}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SubDescription}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}"
                           FontSize="13" HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Unit}"
                           FontSize="13" HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding VatRate}"
                           FontSize="13" HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding UnitPrice}"
                           FontSize="13" HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding NetTotal}"
                           FontSize="13" HorizontalAlignment="Right"
                           VerticalAlignment="Top" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDarkBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- GESTRICHELTE LINIE unten -->
                        <Rectangle Height="1"
       Fill="#CCCCCC"
       HorizontalAlignment="Stretch"
       Margin="0,0,0,4"/>

                    </StackPanel>


                    <!-- ── SUMMENBEREICH ── -->
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ZAHLUNGSINFORMATIONEN links -->
                        <Border Grid.Column="0"
                            Background="{StaticResource LightGrayBrush}"
                            CornerRadius="8" Padding="18,16"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Margin="0,0,20,0"
                            VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="ZAHLUNGSINFORMATIONEN"
                                       Style="{StaticResource LabelSmall}"
                                       Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Bank:" Style="{StaticResource LabelSmall}"
                                           Margin="0,0,12,8"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="Commerzbank AG"
                                           Style="{StaticResource ValueText}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="IBAN:" Style="{StaticResource LabelSmall}"
                                           Margin="0,0,12,8"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="DE89 3704 0044 0532 0130 00"
                                           Style="{StaticResource ValueText}"
                                           FontFamily="Courier New" FontSize="12"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="BIC:" Style="{StaticResource LabelSmall}"
                                           Margin="0,0,12,8"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="COBADEFFXXX"
                                           Style="{StaticResource ValueText}"
                                           FontFamily="Courier New" FontSize="12"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                           Text="Zahlungsziel:" Style="{StaticResource LabelSmall}"
                                           Margin="0,0,12,8"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="14 Tage netto (bis 29.05.2024)"
                                           Style="{StaticResource ValueText}"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                           Text="Verwendungszweck:" Style="{StaticResource LabelSmall}"
                                           Margin="0,0,12,0"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                           Text="RE-2024-00842"
                                           Style="{StaticResource ValueText}"
                                           FontWeight="Bold"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- SUMMENBOX rechts -->
                        <!-- ── SUMMEN ── -->
                        <StackPanel Margin="0,16,0,0" HorizontalAlignment="Right" MinWidth="320" Grid.Column="1">

                            <!-- Summe aller Positionen -->
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Summe aller Positionen"
               FontSize="13" Foreground="{StaticResource TextDarkBrush}"/>
                                <TextBlock Grid.Column="1" Text="3.898,00 €"
               FontSize="13" HorizontalAlignment="Right"
               Foreground="{StaticResource TextDarkBrush}"/>
                            </Grid>

                            <!-- Rabatt -->
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rabatt / Nachlass  3,00 %"
               FontSize="13" Foreground="{StaticResource TextDarkBrush}"/>
                                <TextBlock Grid.Column="1" Text="116,94 €"
               FontSize="13" HorizontalAlignment="Right"
               Foreground="{StaticResource TextDarkBrush}"/>
                            </Grid>

                            <!-- Nettobetrag -->
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Nettobetrag"
               FontSize="13" Foreground="{StaticResource TextDarkBrush}"/>
                                <TextBlock Grid.Column="1" Text="3.781,06 €"
               FontSize="13" HorizontalAlignment="Right"
               Foreground="{StaticResource TextDarkBrush}"/>
                            </Grid>

                            <!-- Steuerbetrag -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Steuerbetrag"
               FontSize="13" FontWeight="Bold"
               Foreground="{StaticResource TextDarkBrush}"/>
                                <TextBlock Grid.Column="1" Text="718,40 €"
               FontSize="13" FontWeight="Bold"
               HorizontalAlignment="Right"
               Foreground="{StaticResource TextDarkBrush}"/>
                            </Grid>

                            <!-- RECHNUNGSBETRAG — grau hinterlegt wie im Beispiel -->
                            <Border Background="#F0F2F5" CornerRadius="6" Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Rechnungsbetrag"
                   FontSize="15" FontWeight="Bold"
                   Foreground="{StaticResource TextDarkBrush}"/>
                                    <TextBlock Grid.Column="1" Text="4.499,46 €"
                   FontSize="15" FontWeight="Bold"
                   HorizontalAlignment="Right"
                   Foreground="{StaticResource TextDarkBrush}"/>
                                </Grid>
                            </Border>

                        </StackPanel>

                    </Grid>

                    <!-- ── NOTIZEN / HINWEISE ── -->
                    <Border Background="#FFF8E1"
                        CornerRadius="6" Padding="16,12"
                        BorderBrush="#FFE082"
                        BorderThickness="1"
                        Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="HINWEISE"
                                   Style="{StaticResource LabelSmall}"
                                   Foreground="#F57F17"
                                   Margin="0,0,0,4"/>
                            <TextBlock Text="Bitte überweisen Sie den Betrag unter Angabe der Rechnungsnummer RE-2024-00842 auf das oben genannte Konto. Bei Fragen wenden Sie sich bitte an unsere Buchhaltung: buchhaltung@mustermann-gmbh.de"
                                   FontSize="12" Foreground="#5D4037"
                                   TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════
      LIEFERANTEN-STATUS PANEL
 ══════════════════════════════════════════ -->
            <Border Background="White"
    CornerRadius="8"
    BorderBrush="{StaticResource BorderBrush}"
    BorderThickness="1"
    Padding="24,18"
    Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── STATUS LINKS ── -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Indikator-Punkt: Grün = bekannt · Gelb = neu -->
                        <Border x:Name="SupplierIndicator"
                Width="12" Height="12" CornerRadius="6"
                Background="#28A745"
                Margin="0,0,10,0"
                VerticalAlignment="Center"/>

                        <StackPanel>
                            <!-- Zustand: BEKANNT -->
                            <StackPanel x:Name="PanelSupplierKnown" Visibility="Visible">
                                <TextBlock Text="Lieferant bekannt · Stammdaten stimmen überein"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#28A745"/>
                                <TextBlock Text="Mustermann GmbH &amp; Co. KG · Lieferanten-ID: LF-0042 · Zuletzt aktualisiert: 03.01.2024"
                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>

                            <!-- Zustand: NICHT VORHANDEN -->
                            <StackPanel x:Name="PanelSupplierNew" Visibility="Collapsed">
                                <TextBlock Text="Lieferant nicht vorhanden · wird neu angelegt"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#E67E00"/>
                                <TextBlock Text="Mustermann GmbH &amp; Co. KG · Noch keine Lieferanten-ID vergeben"
                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── BUTTON RECHTS ── -->

                    <!-- Zustand BEKANNT → grüner Check-Button -->
                    <Button x:Name="BtnCheckSupplier"
            Grid.Column="1"
            Content="✔  Geprüft"
            Visibility="Visible"
            Cursor="Hand"
            VerticalAlignment="Center"
            >
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder"
                        Background="White"
                        BorderBrush="#28A745"
                        BorderThickness="1.5"
                        CornerRadius="6"
                        Padding="16,8">
                                    <TextBlock Text="{TemplateBinding Content}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#28A745"/>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="BtnBorder"
                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                    To="#F0FFF4" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Normal"/>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Zustand NEU → oranger Speichern-Button -->
                    <Button x:Name="BtnSaveSupplier"
            Grid.Column="1"
            Content="💾  Lieferant speichern"
            Visibility="Collapsed"
            Cursor="Hand"
            VerticalAlignment="Center"
           >
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnSaveBorder"
                        Background="#E67E00"
                        BorderThickness="0"
                        CornerRadius="6"
                        Padding="16,8">
                                    <TextBlock Text="{TemplateBinding Content}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="White"/>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="BtnSaveBorder"
                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                    To="#CF6D00" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Normal"/>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>
            </Border>


            <!-- ══════════════════════════════════════════
             AKTIONS-BUTTONS (Bezahlen / Ablehnen)
        ══════════════════════════════════════════ -->
            <Border Background="White"
                CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="24,20"
                Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Info links -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Rechnung freigeben"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextDarkBrush}"/>
                        <TextBlock Text="Nach Freigabe wird die Rechnung in der Buchhaltung erfasst und zur Zahlung vorgemerkt."
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" Margin="0,3,20,0"/>
                    </StackPanel>

                    <!-- Buttons rechts -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" >
                        <Button Content="✖  Ablehnen"
                            Style="{StaticResource SecondaryButton}"/>
                        <Button Content="✔  Zur Zahlung freigeben"
                            Style="{StaticResource PrimaryButton}"
                            Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>