<UserControl x:Class="Tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.DeleteInvoicePositionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tulo.eInvoiceCreatorZUGFeRD.Views.Invoices"
             xmlns:flag="clr-namespace:System;assembly=mscorlib"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:commoncontrols="clr-namespace:tulo.ResourcesWpfLib.Controls.Common;assembly=tulo.ResourcesWpfLib"
             xmlns:extended="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             Focusable="True"
             FocusManager.IsFocusScope="True"
             KeyboardNavigation.TabNavigation="Cycle"
             extended:SetFocusOnModalShow.Enabled="True"
             Background="{StaticResource PanelBrushColor}"
             Style="{StaticResource RoundedUserControlStyle}"
             ToolTipService.InitialShowDelay="500"
             mc:Ignorable="d"
             Width="670"
             Height="Auto"
             d:DesignHeight="330"
             d:DesignWidth="670">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <flag:Boolean x:Key="TrueFlag">True</flag:Boolean>
            <flag:Boolean x:Key="FalseFlag">False</flag:Boolean>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Modifiers="Alt"
                    Key="F4"
                    Command="{Binding CloseDeleteInvoicePositionDetailsCommand}" />
        <KeyBinding Key="Esc" Command="{Binding CloseDeleteInvoicePositionDetailsCommand}" />
    </UserControl.InputBindings>

    <Grid ToolTipService.ShowOnDisabled="True">
        <!--  this definition replace the SizeToContent property, because in user control doesn't exist this property  -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ToolTipService.ShowOnDisabled="True" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="25" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Bar UI Buttons  -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource MainBrushColor}"
                    BorderThickness="0,2,0,0"
                    ClipToBounds="True">
                <Grid Grid.Row="0"
                      Background="{StaticResource MainBrushColor}"
                      Focusable="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="2" />
                    </Grid.ColumnDefinitions>

                    <Image Margin="2,0,0,1"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Width="20"
                           Height="20"
                           Source="/Assets/TuloTeam.ico" />

                    <TextBlock Grid.Column="1"
                               MaxWidth="2000"
                               Padding="2,3,0,0"
                               Foreground="White"
                               Text="{Binding LabelDeleteInvoicePosition}" />

                    <Button x:Name="btnClose"
                            Grid.Column="2"
                            Focusable="False"
                            Style="{StaticResource CloseWinButton}"
                            Width="22"
                            Height="22"
                            Cursor="Hand"
                            Background="{StaticResource MainBrushColor}"
                            BorderBrush="Transparent"
                            Foreground="Transparent"
                            Command="{Binding CloseDeleteInvoicePositionDetailsCommand}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <Grid Width="14" Height="14">
                            <Path Style="{StaticResource WinCloseButtonPathStyle}"
                                  Data="{StaticResource CloseIconSVG}"
                                  Fill="{StaticResource ButtonBrushIconColor}"
                                  Stretch="Fill" />
                        </Grid>
                        <behaviors:Interaction.Triggers>
                            <behaviors:KeyTrigger Key="Esc">
                                <behaviors:InvokeCommandAction Command="{Binding CloseDeleteInvoicePositionDetailsCommand}" />
                            </behaviors:KeyTrigger>
                        </behaviors:Interaction.Triggers>
                    </Button>
                </Grid>
            </Border>

            <!--  Form  -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="14" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="6" />
                </Grid.RowDefinitions>

                <local:InvoicePositionDetailsFormView DataContext="{Binding InvoicePositionDetailsFormViewModel}"
                                                      Grid.Row="1"
                                                      IsEnabled="False" />

                <commoncontrols:StatusMessageControl Grid.Row="2"
                                                     Margin="0,8,0,0"
                                                     Grid.Column="1"
                                                     Grid.ColumnSpan="1"
                                                     DataContext="{Binding StatusMessageViewModel}" />
            </Grid>

            <!--  Bar Form Buttons  -->
            <Border Grid.Row="2" BorderBrush="{StaticResource GroupBoxBrushColor}">
                <Grid Background="{StaticResource PanelBrushColor}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="5" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="5" />
                    </Grid.RowDefinitions>

                    <Button Name="requestedReturnButton"
                            Grid.Column="1"
                            Grid.Row="1"
                            Margin="0,2,0,2"
                            Style="{StaticResource ToolbarSecondaryButton}"
                            KeyboardNavigation.AcceptsReturn="False"
                            IsEnabled="{Binding IsSaveRequestMessageVisible, Converter={StaticResource InverseBoolConverter}}"
                            ToolTip="{Binding ToolTipReturn}"
                            Command="{Binding CloseDeleteInvoicePositionDetailsCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource ArrowBackIconSVG}"
                                  Fill="{StaticResource ButtonIconPrimaryColorBrush}"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />
                            <AccessText Text="{Binding ContentButtonReturn}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Name="doneButton"
                            Grid.Column="3"
                            Grid.Row="1"
                            Margin="0,2,0,2"
                            Style="{StaticResource ToolbarDangerButton}"
                            ToolTip="{Binding ToolTipSave}"
                            KeyboardNavigation.AcceptsReturn="False"
                            IsEnabled="{Binding IsEnableToSaveData}"
                            Command="{Binding DeleteInvoicePositionDetailsCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource DeleteIconSVG}"
                                  Fill="Red"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />
                            <AccessText Text="{Binding ContentButtonDeletePosition}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
