<UserControl x:Class="Tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.InvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tulo.eInvoiceCreatorZUGFeRD.Views.Invoices"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             xmlns:behaviorsutilities="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             xmlns:commoncommands="clr-namespace:tulo.ResourcesWpfLib.Commands;assembly=tulo.ResourcesWpfLib"
             xmlns:commoncontrols="clr-namespace:tulo.ResourcesWpfLib.Controls.Common;assembly=tulo.ResourcesWpfLib"
             xmlns:invoicecontrols="clr-namespace:Tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls"
             xmlns:slidecontrol="clr-namespace:tulo.SlideToComfirmControl;assembly=tulo.SlideToComfirmControl"
             xmlns:controls="clr-namespace:Tulo.eInvoiceCreatorZUGFeRD.Views.Invoices.Controls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:diag="clr-namespace:System.Diagnostics;assembly=WindowsBase"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="730">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter"
                                                  TrueLength="*"
                                                  FalseLength="0" />
            <converters:CheckDefaultDateConverter x:Key="CheckDefaultDateConverter" />
            <converters:InactiveSinceToBackgroundColorConverter x:Key="InactiveSinceToBackgroundColorConverter" />
            <converters:MultiCommandParameterConverter x:Key="MultiCommandParameterConverter" />
            <system:Boolean x:Key="TrueFlag">True</system:Boolean>
            <system:Boolean x:Key="FalseFlag">False</system:Boolean>

            <Style TargetType="{x:Type CheckBox}" x:Key="ModernCheckBox">
                <Setter Property="Margin" Value="8" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="SnapsToDevicePixels" Value="true" />
                <Setter Property="OverridesDefaultStyle" Value="true" />
                <Setter Property="Foreground" Value="#333333" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type CheckBox}">
                            <BulletDecorator Background="Transparent">
                                <BulletDecorator.Bullet>
                                    <Border x:Name="Border"
                                            Width="20"
                                            Height="20"
                                            CornerRadius="4"
                                            BorderThickness="2"
                                            BorderBrush="#CCCCCC"
                                            Background="White">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="1"
                                                              Opacity="0.15"
                                                              BlurRadius="2" />
                                        </Border.Effect>
                                        <Path x:Name="CheckMark"
                                              Data="M 2 8 L 7 13 L 15 2"
                                              Stroke="#2952CC"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Stretch="Uniform"
                                              Visibility="Hidden" />
                                    </Border>
                                </BulletDecorator.Bullet>
                                <ContentPresenter Margin="8,0,0,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  RecognizesAccessKey="True" />
                            </BulletDecorator>

                            <ControlTemplate.Triggers>
                                <!--  Checked State  -->
                                <Trigger Property="IsChecked" Value="true">
                                    <Setter TargetName="Border" Property="Background" Value="#2952CC" />
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#2952CC" />
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="CheckMark" Property="Stroke" Value="White" />
                                </Trigger>

                                <!--  Hover State  -->
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#999999" />
                                    <Setter TargetName="Border" Property="Background" Value="#F5F5F5" />
                                </Trigger>

                                <!--  Checked + Hover State  -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked" Value="true" />
                                        <Condition Property="IsMouseOver" Value="true" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Border" Property="Background" Value="#2952CC" />
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#2952CC" />
                                </MultiTrigger>

                                <!--  Focused State  -->
                                <Trigger Property="IsFocused" Value="true">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#2196F3" />
                                    <Setter TargetName="Border" Property="BorderThickness" Value="2" />
                                </Trigger>

                                <!--  Disabled State  -->
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter TargetName="Border" Property="Background" Value="#EEEEEE" />
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#DDDDDD" />
                                    <Setter TargetName="CheckMark" Property="Stroke" Value="#AAAAAA" />
                                    <Setter Property="Foreground" Value="#AAAAAA" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid"
          ToolTipService.ShowOnDisabled="True"
          FocusManager.FocusedElement="{Binding ElementName=currentListView}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="672" />
            <ColumnDefinition Width="*" />
            <!--<ColumnDefinition Width="{Binding IsPreviewEnabled, Converter={StaticResource BoolToGridLengthConverter}}" />-->

        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Border Background="White"
                        CornerRadius="8"
                        BorderThickness="1"
                        Padding="16,10"
                        Margin="10,4,10,4">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  ── Left Buttons ──  -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Button Name="saveButton"
                                    Style="{StaticResource ToolbarPrimaryButton}"
                                    ToolTip="{Binding ToolTipSaveCustomerData}"
                                    Command="{Binding SaveCustomerDataCommand}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Data="{StaticResource SaveDataIconSVG}"
                                          Fill="White"
                                          Width="14"
                                          Height="14"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                    <AccessText Text="{Binding ContentButtonSave}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Name="loadButton"
                                    Style="{StaticResource ToolbarSecondaryButton}"
                                    ToolTip="{Binding ToolTipLoadCustomerData}"
                                    Command="{Binding LoadCustomerDataCommand}"
                                    Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Data="{StaticResource LoadCustomerDataIconSVG}"
                                          Fill="{StaticResource ButtonIconPrimaryColorBrush}"
                                          Width="14"
                                          Height="14"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                    <AccessText Text="{Binding ContentButtonLoad}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Name="clearAllButton"
                                    Style="{StaticResource ToolbarDangerButton}"
                                    ToolTip="{Binding ToolTipClearAllInvoiceView}"
                                    Command="{Binding ClearAllInvoiceViewCommand}"
                                    Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Data="{StaticResource ClearAllIconSVG}"
                                          Fill="Red"
                                          Width="14"
                                          Height="14"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                    <AccessText Text="{Binding ContentButtonClearAll}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                        </StackPanel>

                        <!--  Vertical separator  -->
                        <Rectangle Grid.Column="3"
                                   Fill="#E2E8F0"
                                   Width="1"
                                   Margin="0,6" />

                        <!--  ── Preview Label + Toggle ──  -->
                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0">

                            <ToggleButton IsChecked="{Binding IsPreviewEnabled, Mode=TwoWay}"
                                          Content="{Binding LabelContentPreview}"
                                          VerticalAlignment="Center"
                                          ToolTip="{Binding ToolTipCreatePreviewElectronicInvoice}"
                                          Style="{StaticResource ToolbarToggleButton}"
                                          Command="{Binding CreateElectronicInvoiceComponentsCommand}">
                                <ToggleButton.CommandParameter>
                                    <MultiBinding Converter="{StaticResource MultiCommandParameterConverter}">
                                        <Binding RelativeSource="{RelativeSource AncestorType=Window}" />
                                        <Binding Path="IsChecked" RelativeSource="{RelativeSource Self}" />
                                    </MultiBinding>
                                </ToggleButton.CommandParameter>
                            </ToggleButton>

                        </StackPanel>


                        <!--  Vertical separator  -->
                        <Rectangle Grid.Column="5"
                                   Fill="#E2E8F0"
                                   Width="1"
                                   Margin="0,6" />

                        <!--  ── Slide-to-Confirm ──  -->
                        <slidecontrol:SlideToConfirm Grid.Column="6"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Margin="12,0,0,0"
                                                     Text="{Binding ContentSlideText}"
                                                     ToolTip="{Binding ToolTipCreateElectronicInvoice}"
                                                     ConfirmedText="{Binding ContentSlideConfirmedText}"
                                                     ConfirmCommand="{Binding CreateElectronicInvoiceComponentsCommand}"
                                                     ResetSignal="{Binding ResetSlideButton}"
                                                     Width="100"
                                                     Height="34"
                                                     FillBrush="#3B82F6"
                                                     TrackBrush="{StaticResource ButtonIconPrimaryColorBrush}"
                                                     ThumbBrush="#FFFFFF"
                                                     ThumbHoverBrush="{StaticResource ButtonIconPrimaryColorBrush}"
                                                     TrackHoverBrush="{StaticResource BackgroundTextBoxDisableBrushColor}"
                                                     TextBrush="White"
                                                     TextHoverBrush="{StaticResource ButtonIconPrimaryColorBrush}">
                            <slidecontrol:SlideToConfirm.ConfirmCommandParameter>
                                <MultiBinding Converter="{StaticResource MultiCommandParameterConverter}">
                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" />
                                    <Binding Source="{StaticResource FalseFlag}" />
                                    <Binding Source="{StaticResource TrueFlag}" />
                                </MultiBinding>
                            </slidecontrol:SlideToConfirm.ConfirmCommandParameter>
                        </slidecontrol:SlideToConfirm>

                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="18" />

                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="2" Grid.Column="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />

                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" HorizontalAlignment="Left">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <!--  Content="Buyer Information"  -->
                        <Label Content="{Binding LabelContenBuyerInformation}"
                               Grid.Row="0"
                               FontWeight="Bold"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="0,0" />
                        <controls:BuyerPartyControl Grid.Row="1" HorizontalAlignment="Left" />
                    </Grid>

                    <Grid Grid.Column="2" HorizontalAlignment="Left">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />

                        </Grid.RowDefinitions>
                        <!--  Content="Header"  -->
                        <Label Content="{Binding LabelContentHeader}"
                               Grid.Row="0"
                               FontWeight="Bold"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="0,0" />
                        <invoicecontrols:HeaderInvoiceControl Grid.Row="1" HorizontalAlignment="Left" />
                    </Grid>

                </Grid>

                <Grid Grid.Row="4"
                      Grid.Column="1"
                      HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!--  Content="Payment Information"  -->
                    <Label Content="{Binding LabelContentPaymentInformation}"
                           FontWeight="Bold"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="0,0" />
                    <controls:PaymentInfosControl Grid.Row="1" />
                </Grid>

                <Grid Grid.Row="6"
                      Grid.Column="1"
                      HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="4" />
                        </Grid.ColumnDefinitions>
                        <Label Content="{Binding LabelContentPaymentTerms}"
                               Grid.Column="0"
                               FontWeight="Bold"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="0,0" />

                        <Label Content="{Binding LabelApplyDiscount}"
                               Grid.Column="2"
                               HorizontalAlignment="Center" />

                        <!--  Checkbox  -->
                        <CheckBox Grid.Column="3"
                                  VerticalAlignment="Center"
                                  Foreground="#374151"
                                  Margin="12,0,0,0"
                                  Style="{StaticResource ModernCheckBox}"
                                  IsChecked="{Binding HasDiscount, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <invoicecontrols:PaymentTermsControl Grid.Row="1"
                                                         HorizontalAlignment="Left"
                                                         Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                </Grid>

                <Grid Grid.Row="8" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!--  Content="Positions List"  -->
                    <Label Content="{Binding LabelContentPositionsList}"
                           Grid.Row="0"
                           FontWeight="Bold"
                           HorizontalAlignment="Left"
                           Margin="0,0" />
                    <invoicecontrols:HeaderInvoicePositionControl Grid.Row="1"
                                                                  HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Stretch" />
                    <Grid Grid.Row="2"
                          Grid.Column="1"
                          Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <ListView Grid.Row="0"
                                  Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Padding="0,0,1,1"
                                  x:Name="currentListView"
                                  SelectionMode="Single"
                                  behaviorsutilities:DynamicUniformGridColumns.MinItemWidth="220"
                                  behaviorsutilities:DynamicUniformGridColumns.MaxItemHeight="180"
                                  behaviorsutilities:ListGridViewSortByHeader.AutoSort="True"
                                  ItemsSource="{Binding InvoicePositionCardListItemCollectionView}"
                                  SelectedItem="{Binding SelectedInvoicePositionCardListItemViewModel, Mode=TwoWay}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True"
                                  behaviorsutilities:CustomMouseWheelScrolling.HandleMouseWheel="True">

                            <ListView.Resources>
                                <Style TargetType="{x:Type GridViewColumnHeader}">
                                    <Setter Property="Height" Value="0" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GridViewColumnHeader" />
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.Resources>

                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">

                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Top" />
                                    <Setter Property="Margin" Value="4" />
                                    <Setter Property="MinWidth" Value="220" />
                                    <Setter Property="MaxHeight" Value="180" />
                                    <Setter Property="Width" Value="Auto" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        SnapsToDevicePixels="True"
                                                        BorderThickness="0">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FF007ACC" />
                                                        <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <!--  DoubleClick ListViewItem  -->
                            <behaviors:Interaction.Behaviors>
                                <behaviorsutilities:ListViewItemDoubleClick />
                            </behaviors:Interaction.Behaviors>
                            <ListView.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenEditInvoicePositionViewCommand}" />
                            </ListView.InputBindings>
                            <!--  End DoubleClick ListViewItem  -->
                        </ListView>
                    </Grid>
                </Grid>

                <!--<commoncontrols:SpinnerMessageControl Grid.Row="5"
                                                  Grid.Column="1"
                                                  Panel.ZIndex="10"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Visibility="{Binding IsLoading, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />-->

                <!--<commoncontrols:StatusMessageControl Grid.Row="7"
                                                     Grid.Column="1"
                                                     DataContext="{Binding StatusMessageViewModel}" />-->
            </Grid>
        </Grid>

        <invoicecontrols:PreviewInvoiceControl Grid.Column="1" Visibility="{Binding DataContext.IsPreviewEnabled, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />

        <!--<Label Content="To Test if works"
               Grid.Column="1"
               Visibility="{Binding DataContext.IsPreviewEnabled, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}" />-->

    </Grid>
</UserControl>